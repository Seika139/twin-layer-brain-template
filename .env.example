# second-brain 環境変数
# このファイルを .env にコピーして値を設定する
# cp .env.example .env

# --- 認証 (VPS 公開時に必須) ---
# SECOND_BRAIN_API_TOKEN=
# GITHUB_WEBHOOK_SECRET=

# --- サーバー設定 ---
# SECOND_BRAIN_PORT=15200
# SECOND_BRAIN_HOST=127.0.0.1

# --- LLM (Web クリップの自動要約・タグ生成) ---
# 優先順位: OPENAI > GEMINI > ANTHROPIC (SECOND_BRAIN_LLM_PRIORITY で変更可能)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# SECOND_BRAIN_LLM_PRIORITY=openai,gemini,anthropic

# --- Embedding (セマンティック検索) ---
# OPENAI_API_KEY が設定されていれば自動で有効になる
