# twin-layer-brain 環境変数
# このファイルを .env にコピーして値を設定する
# cp .env.example .env

# --- 認証 ---
# BRAIN_API_TOKEN は `mise run reset-token` で .env に作成・更新できる
# BRAIN_API_TOKEN=
# GITHUB_WEBHOOK_SECRET=

# --- サーバー設定 ---
# BRAIN_PORT=15200
# BRAIN_HOST=127.0.0.1
# BRAIN_MCP_REQUIRE_TOKEN=false

# --- LLM (Web クリップの自動要約・タグ生成) ---
# 優先順位: OPENAI > GEMINI > ANTHROPIC (BRAIN_LLM_PRIORITY で変更可能)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# BRAIN_LLM_PRIORITY=openai,gemini,anthropic

# --- Embedding (セマンティック検索) ---
# OPENAI_API_KEY が設定されていれば自動で有効になる

# --- TLS CA bundle (MITM プロキシ環境向け: Netskope / Zscaler など) ---
# プロキシが TLS を開いて自社 CA で署名し直す環境では、certifi バンドルだけでは OpenAI など外部 API への接続が CERTIFICATE_VERIFY_FAILED になる。
# certifi の CA に社内 CA を連結した合成バンドルを用意し、両変数で指す。
# 作り方は docs/instance-setup.md 「MITM プロキシ環境の TLS 設定」を参照。
# SSL_CERT_FILE=/Users/<username>/.config/ssl/ca-bundle-with-corp.pem
# REQUESTS_CA_BUNDLE=/Users/<username>/.config/ssl/ca-bundle-with-corp.pem
