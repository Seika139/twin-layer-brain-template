# twin-layer-brain 環境変数
# このファイルを .env にコピーして値を設定する
# cp .env.example .env

# --- 認証 ---
# BRAIN_API_TOKEN は `mise run reset-token` で .env に作成・更新できる
# BRAIN_API_TOKEN=
# GITHUB_WEBHOOK_SECRET=

# --- サーバー設定 ---
# BRAIN_PORT=15200
# BRAIN_HOST=127.0.0.1
# BRAIN_MCP_REQUIRE_TOKEN=false

# --- LLM (Web クリップの自動要約・タグ生成) ---
# 優先順位: OPENAI > GEMINI > ANTHROPIC (BRAIN_LLM_PRIORITY で変更可能)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# BRAIN_LLM_PRIORITY=openai,gemini,anthropic

# --- Embedding (セマンティック検索) ---
# OPENAI_API_KEY が設定されていれば自動で有効になる

# MITM プロキシ環境 (Netskope, Zscaler, Blue Coat など) の TLS 検証は
# OS トラストストア (macOS Keychain / Linux openssl / Windows SChannel) を
# truststore 経由で使うため、個別の CA bundle 変数は不要です。詳細は
# docs/instance-setup.md 「MITM プロキシ環境の TLS 設定」節を参照。
